# Chainora protocol addresses
VITE_CHAINORA_REGISTRY_ADDRESS=
VITE_CHAINORA_FACTORY_ADDRESS=
VITE_CHAINORA_POOL_IMPLEMENTATION_ADDRESS=
VITE_CHAINORA_STABLECOIN_ADDRESS=

# Chainora display config
VITE_CHAINORA_CURRENCY_SYMBOL=tCNR
VITE_CHAINORA_CONTRIBUTION_SYMBOL=tcUSD
VITE_CHAINORA_TOKEN_DECIMALS=18

VITE_CHAINORA_RPC_URL=/rpc/chainora
VITE_CHAINORA_CHAIN_ID=

# Initia wallet / username lookup
# Keep username lookup disabled by default. Enable it and set a compatible API/LCD
# endpoint only when your environment supports Initia username routes.
VITE_INTERWOVEN_NETWORK=testnet
VITE_INTERWOVEN_DEFAULT_CHAIN_ID=initiation-2
VITE_ENABLE_INITIA_USERNAME_LOOKUP=false
VITE_INITIA_API_URL=
VITE_INITIA_LCD_URL=
